<?xml version="1.0" encoding="UTF-8"?>
<configuration>

  <!-- stdout (Promtail 수집용 / AU-2) -->
  <appender name="console" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>%d{yyyy-MM-dd'T'HH:mm:ss.SSS'Z', UTC} %5level [%thread] %logger{36} : %msg%n</pattern>
    </encoder>
  </appender>

  <!-- OTel Java Agent가 자동으로 OTLP 브릿징 처리 (SP 800-204D §4.3) -->

  <logger name="com.jccompany" level="INFO" additivity="false">
    <appender-ref ref="console" />
  </logger>

  <logger name="org.springframework.web" level="INFO" additivity="false">
    <appender-ref ref="console" />
  </logger>

  <root level="WARN">
    <appender-ref ref="console" />
  </root>

</configuration>
