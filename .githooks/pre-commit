#!/bin/bash
# Pre-commit hook: Gitleaks secret scanning + Semgrep SAST
# SP 800-204D §5.1.4 / SSDF PS.1.1, PW.7.2 / DoD Guidebook Table 5
#
# 설치 (개인):
#   cp pre-commit .git/hooks/pre-commit
#   chmod +x .git/hooks/pre-commit
#
# 설치 (팀 전체):
#   mkdir -p .githooks && cp pre-commit .githooks/pre-commit
#   chmod +x .githooks/pre-commit
#   git config core.hooksPath .githooks/

set -eo pipefail

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 1. Gitleaks — 시크릿 탐지 (필수, 1~3초)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
if command -v gitleaks &> /dev/null; then
  echo "🔍 [1/2] Gitleaks secret scanning..."
  if ! gitleaks git --staged --no-banner -v 2>/dev/null; then
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "🔴 SECRET DETECTED — 커밋 차단"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    echo "해결: 시크릿을 제거하고 환경변수/.env로 이동"
    echo "오탐: .gitleaksignore에 fingerprint 추가"
    echo "우회: SKIP=gitleaks git commit (권장하지 않음)"
    exit 1
  fi
  echo "✅ Gitleaks: No secrets detected"
else
  echo "⚠️  gitleaks not installed — skipping secret scan"
  echo "   설치: brew install gitleaks (macOS) | apt install gitleaks (Linux)"
fi

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 2. Semgrep — SAST 보안 취약점 (권장, 5~15초)
#    SKIP=semgrep git commit 으로 건너뛸 수 있음
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
if [[ "$SKIP" == *"semgrep"* ]]; then
  echo "⏭️  Semgrep skipped (SKIP=semgrep)"
elif command -v semgrep &> /dev/null; then
  echo "🔍 [2/2] Semgrep SAST scanning (staged files only)..."
  # staged된 파일 목록 추출
  STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(java|py|js|ts|go|rb|php)$' || true)
  if [ -n "$STAGED_FILES" ]; then
    if ! echo "$STAGED_FILES" | xargs semgrep --config=auto --error --quiet 2>/dev/null; then
      echo ""
      echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
      echo "🟡 SAST FINDING — 보안 취약점 발견"
      echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
      echo ""
      echo "상세: semgrep --config=auto <파일> 으로 확인"
      echo "우회: SKIP=semgrep git commit (CI에서 다시 스캔됨)"
      exit 1
    fi
    echo "✅ Semgrep: No security issues found"
  else
    echo "✅ Semgrep: No scannable files staged"
  fi
else
  echo "⏭️  semgrep not installed — skipping SAST"
  echo "   설치: pip install semgrep | brew install semgrep"
fi

echo ""
echo "✅ Pre-commit checks passed"
